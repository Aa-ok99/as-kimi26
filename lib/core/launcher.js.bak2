const chalk = require('chalk');
const { initializeOllamaClient } = require('../lib/tools/ollama-client');
const { loadConfig } = require('../utils/config');
const { setupLogging } = require('../utils/logger');

class Launcher {
  constructor() {
    this.config = null;
    this.agents = new Map();
  }

  async initialize() {
    console.log(chalk.cyan('Initializing Kimi 2.6 Launcher...'));
    
    this.config = loadConfig();
    setupLogging(this.config.logging);
    
    await initializeOllamaClient(this.config.ollama);
    this.loadAgents();
    
    console.log(chalk.green('✓ Kimi 2.6 initialized successfully!'));
    return this;
  }

  loadAgents() {
    const agentFiles = [
      'code-architect',
      'security-auditor',
      'data-guardian',
      'performance-engineer'
    ];
    
    agentFiles.forEach(agentName => {
      try {
        const AgentClass = require(`../agents/${agentName}`);
        this.agents.set(agentName, new AgentClass());
      } catch (error) {
        console.warn(chalk.yellow(`Agent ${agentName} not found: ${error.message}`));
      }
    });
  }

  async runAgent(agentName, ...args) {
    const agent = this.agents.get(agentName);
    if (!agent) {
      throw new Error(`Agent '${agentName}' not found`);
    }
    return agent.execute(...args);
  }
}

module.exports = {
  initialize: () => new Launcher().initialize()
};