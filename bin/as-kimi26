#!/usr/bin/env node

const { Command } = require('commander');
const chalk = require('chalk');
const launcher = require('../lib/core/launcher');

const program = new Command();

program
  .name('as-kimi26')
  .alias('kimi')
  .description('Kimi 2.6 Multi-Agent Launcher for Termux')
  .version('1.0.0');

program
  .command('start')
  .description('Start the AI-powered coding assistant')
  .action(() => {
    console.log(chalk.green('Starting Kimi 2.6...'));
    launcher.initialize();
  });

program
  .command('agent <name>')
  .description('Run a specific agent')
  .argument('<name>', 'agent name')
  .action((name) => {
    console.log(chalk.yellow(`Running agent: ${name}`));
  });

program.parse();
